#compdef shellfire

_shellfire() {
  local -a commands
  commands=(
    'list:List all terminal sessions'
    'ls:List all terminal sessions'
    'attach:Attach/focus a session by name'
    'new:Create a new terminal session'
    'send:Send input to a named session'
    'kill:Kill a terminal session by name'
    'rename:Rename a terminal session'
    'remote:Discover & open remote sessions'
  )

  _arguments -C \
    '1:command:->cmd' \
    '*::arg:->args'

  case $state in
    cmd)
      _describe 'command' commands
      ;;
    args)
      case $words[1] in
        attach|send|kill|rename)
          _arguments \
            '(-t --target)'{-t,--target}'[Target session name]:name:_shellfire_sessions'
          ;;
        new)
          _arguments \
            '(-t --target)'{-t,--target}'[Session name]:name' \
            '(-d --dir)'{-d,--dir}'[Working directory]:dir:_files -/'
          ;;
        remote)
          _arguments \
            '1:user@host' \
            '(-p --port)'{-p,--port}'[SSH port]:port' \
            '(-w --password)'{-w,--password}'[SSH password]:password'
          ;;
      esac
      ;;
  esac
}

_shellfire_sessions() {
  local -a sessions
  local output
  output=$(shellfire list 2>/dev/null) || return
  sessions=(${(f)output})
  _describe 'session' sessions
}

_shellfire "$@"
