{
  "name": "terminator",
  "version": "1.0.0",
  "description": "A modern terminal multiplexer built with Electron",
  "main": "main.js",
  "author": "Suvash Bhusal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/suvash-glitch/Terminator.git"
  },
  "homepage": "https://github.com/suvash-glitch/Terminator#readme",
  "bin": {
    "terminator": "./bin/terminator-cli.js"
  },
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "test": "node --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.4.0",
    "electron": "^35.0.0",
    "electron-updater": "^6.0.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0"
  },
  "build": {
    "appId": "com.terminator.app",
    "productName": "Terminator",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "bin/**/*",
      "node_modules/**/*"
    ],
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": ["nsis", "zip"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "icon": "assets/icon.png"
    }
  }
}
