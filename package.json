{
  "name": "shellfire",
  "version": "2.0.0",
  "description": "AI-powered terminal multiplexer with split panes, pipelines, extensions, and remote sessions",
  "main": "main.js",
  "author": {
    "name": "Suvash Bhusal",
    "email": "suvash@shellfire.dev"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/suvash-glitch/Shellfire.git"
  },
  "homepage": "https://github.com/suvash-glitch/Shellfire#readme",
  "bin": {
    "shellfire": "./bin/shellfire-cli.js"
  },
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "test": "node --test test/main.test.js test/renderer.test.js test/security.test.js test/cli.test.js test/plugins.test.js test/ipc.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.4.0",
    "electron-updater": "^6.0.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0"
  },
  "build": {
    "appId": "com.shellfire.app",
    "productName": "Shellfire",
    "icon": "assets/icon.png",
    "publish": {
      "provider": "github",
      "owner": "suvash-glitch",
      "repo": "Shellfire"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "bin/**/*",
      "node_modules/**/*"
    ],
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": ["nsis", "zip"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "icon": "assets/icon.png"
    }
  }
}
